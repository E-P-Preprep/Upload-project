{
  "name": "vimeo-upload-backend",
  "version": "1.0.0",
  "description": "Secure backend for Vimeo upload portal — token proxy + M365 email notifications",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "[ -f zscaler-ca.pem ] && export NODE_EXTRA_CA_CERTS=./zscaler-ca.pem; node server.js",
    "dev": "[ -f zscaler-ca.pem ] && export NODE_EXTRA_CA_CERTS=./zscaler-ca.pem; node --watch server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0"
  }
}
